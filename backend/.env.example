# Puerto donde corre el servidor Express
PORT=4000

# Clave secreta para firmar los tokens JWT.
# Cambiala por cualquier texto largo y aleatorio antes de usar en producción.
JWT_SECRET=cambia-esta-clave-por-una-bien-larga-y-secreta

# Tiempo de expiración del token (formato soportado por jsonwebtoken)
JWT_EXPIRES_IN=7d
